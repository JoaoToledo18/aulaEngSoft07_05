@startuml

left to right direction

actor "Funcionário/Administrador" as Admin
actor "Espectador" as Cliente

rectangle "Sistema de Rede de Cinemas" {

    usecase "Gerenciar Cinemas" as UC1
    usecase "Gerenciar Filmes" as UC2
    usecase "Gerenciar Sessões" as UC3
    usecase "Registrar Público" as UC4
    usecase "Consultar Público" as UC5

    usecase "Consultar Programação" as UC6
    usecase "Consultar Informações\n dos Filmes" as UC7
}

Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC4
Admin --> UC5

Cliente --> UC6
Cliente --> UC7

@enduml